{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://test.banasave.com/api",
        "EXPO_PUBLIC_WS_URL": "wss://test.banasave.com/socket/websocket",
        "EXPO_PUBLIC_RTMP_HOST": "test.banasave.com",
        "EXPO_PUBLIC_RTMP_SECURE": "false"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://test.banasave.com/api",
        "EXPO_PUBLIC_WS_URL": "wss://test.banasave.com/socket/websocket",
        "EXPO_PUBLIC_RTMP_HOST": "test.banasave.com",
        "EXPO_PUBLIC_RTMP_SECURE": "false"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
