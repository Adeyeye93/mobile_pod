{
  "expo": {
    "name": "Echo",
    "slug": "pod_mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-dark.png",
    "scheme": "podmobile",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "seyi091",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "googleServicesFile": "./android/app/google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo-dark.png",
        "backgroundColor": "#1F222A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.echo",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [{ "scheme": "podmobile" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo-dark.png",
          "color": "#e63946",
          "sounds": []
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1F222A",
          "dark": {
            "image": "./assets/images/logo.png",
            "backgroundColor": "#1F222A"
          }
        }
      ],
      "expo-font",
      [
        "expo-audio",
        {
          "audioMode": {
            "playsInSilentModeIOS": true,
            "staysActiveInBackground": true,
            "interruptionModeIOS": "duckOthers",
            "interruptionModeAndroid": "duckOthers",
            "recordAudioAndroid": true
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Echo to access your photos to set a channel avatar."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "309df184-fded-48cc-a39f-3827495a7d0f"
      }
    }
  }
}
